# Application
APP_NAME=RingCentral Call Summary Pipeline
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ringcentral_db

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# RingCentral OAuth
RINGCENTRAL_CLIENT_ID=your-ringcentral-client-id
RINGCENTRAL_CLIENT_SECRET=your-ringcentral-client-secret
RINGCENTRAL_OAUTH_URL=https://platform.ringcentral.com/oauth/authorize
RINGCENTRAL_TOKEN_URL=https://platform.ringcentral.com/oauth/token
RINGCENTRAL_API_BASE_URL=https://platform.ringcentral.com/restapi/v1.0
RINGCENTRAL_REDIRECT_URI=http://localhost:8000/api/v1/ringcentral/callback

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Sheets
GOOGLE_SHEETS_CLIENT_ID=your-google-client-id
GOOGLE_SHEETS_CLIENT_SECRET=your-google-client-secret
GOOGLE_SHEETS_REDIRECT_URI=http://localhost:8000/api/v1/sheets/oauth/callback

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
